<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#780000"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MotivationActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Motivation page"
            android:textSize="25sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#720048"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/image1"
            android:scaleType="center"/>
        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Motivation Tips\n\n1. Set Clear Goals\nKnow what you want to achieve.\n\n2. Stay Positive\nBelieve in yourself.\n\n3. Track Progress\nSee how far you’ve come.\n\n4. Reward Yourself\nCelebrate small wins.\n\n5. Avoid Negativity\nStay around positive people.\n\n6. Stay Consistent\nKeep going even when it’s hard.\n\n7. Visualize Success\nImagine achieving your goals.\n\n8. Learn from Failure\nMistakes help you grow.\n\n9. Stay Focused\nAvoid distractions.\n\n10. Never Give Up\nPersistence leads to success."
            android:textSize="16sp"
            android:textColor="#000000"
            android:padding="16dp"/>

    </LinearLayout>

</ScrollView>