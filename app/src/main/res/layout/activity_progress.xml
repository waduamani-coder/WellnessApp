<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#345678"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProgressActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Progress page"
            android:textSize="25sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#720048"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/image1"
            android:scaleType="center"/>
        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Track Your Progress\n\n1. Set Goals\nDefine what you want to achieve.\n\n2. Record Workouts\nKeep track of exercises done.\n\n3. Monitor Weight\nCheck changes regularly.\n\n4. Take Notes\nWrite down improvements.\n\n5. Stay Consistent\nTrack daily or weekly.\n\n6. Use Apps\nHelps in monitoring progress.\n\n7. Measure Performance\nCheck strength and endurance.\n\n8. Stay Motivated\nSee your growth over time.\n\n9. Adjust Goals\nImprove targets gradually.\n\n10. Celebrate Progress\nAcknowledge achievements."
            android:textSize="16sp"
            android:textColor="#40ff00"
            android:padding="16dp"/>

    </LinearLayout>

</ScrollView>