<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#326753"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HydrationActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hydration page"
            android:textSize="25sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#720048"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/image1"
            android:scaleType="center"/>
        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hydration Tips\n\n1. Drink Water Regularly\nAim for 6–8 glasses daily.\n\n2. Start Your Day with Water\nHelps kickstart metabolism.\n\n3. Carry a Water Bottle\nMakes it easier to stay hydrated.\n\n4. Eat Water-Rich Foods\nFruits like watermelon and oranges.\n\n5. Avoid Sugary Drinks\nThey can dehydrate your body.\n\n6. Drink After Exercise\nReplenish lost fluids.\n\n7. Set Reminders\nHelps you drink water consistently.\n\n8. Check Urine Color\nLight color means good hydration.\n\n9. Drink Before Meals\nHelps digestion.\n\n10. Stay Hydrated Always\nEssential for overall health."
            android:textSize="16sp"
            android:textColor="#fdf500"
            android:padding="16dp"/>

    </LinearLayout>


</ScrollView>