<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#757000"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MeditationActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meditation page"
            android:textSize="25sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#720048"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/image1"
            android:scaleType="center"/>
        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meditation Guide\n\n1. Find a Quiet Place\nAvoid distractions.\n\n2. Sit Comfortably\nKeep your back straight.\n\n3. Focus on Breathing\nInhale and exhale slowly.\n\n4. Start Small\nBegin with 5–10 minutes.\n\n5. Clear Your Mind\nLet thoughts pass without focus.\n\n6. Use Guided Meditation\nApps or videos can help beginners.\n\n7. Practice Daily\nConsistency improves results.\n\n8. Relax Your Body\nRelease tension in muscles.\n\n9. Stay Present\nFocus on the moment.\n\n10. End Gently\nSlowly return to normal activity."
            android:textSize="16sp"
            android:textColor="#c5c59c"
            android:padding="16dp"/>


    </LinearLayout>


</ScrollView>