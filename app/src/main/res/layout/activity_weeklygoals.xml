<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#0d563b"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WeeklyGoalsActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WeeklyGoals page"
            android:textSize="25sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#0062ff" />
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/image2"
            android:scaleType="center"/>
        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly Goals Plan\n\n1. Plan Your Week\nSet clear weekly targets.\n\n2. Exercise 3–5 Times\nStay active regularly.\n\n3. Eat Healthy Meals\nMaintain a good diet.\n\n4. Stay Hydrated\nDrink enough water daily.\n\n5. Get Enough Sleep\nAim for 7–8 hours.\n\n6. Practice Meditation\nRelax your mind.\n\n7. Avoid Junk Food\nStay disciplined.\n\n8. Track Your Progress\nReview your achievements.\n\n9. Stay Consistent\nFollow your plan daily.\n\n10. Reflect Weekly\nEvaluate and improve goals."
            android:textSize="16sp"
            android:textColor="#ebc400"
            android:padding="16dp"/>



    </LinearLayout>

</ScrollView>